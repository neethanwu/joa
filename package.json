{
  "name": "joa",
  "version": "0.1.0",
  "type": "module",
  "description": "Journal of Agents — persistent activity journal for AI agents",
  "main": "dist/core/index.js",
  "bin": {
    "joa": "dist/cli/main.js"
  },
  "files": ["dist/"],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neethanwu/joa.git"
  },
  "keywords": [
    "ai",
    "agent",
    "journal",
    "mcp",
    "memory",
    "claude",
    "cursor",
    "llm",
    "activity-log"
  ],
  "scripts": {
    "test": "bun test",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && test -s dist/cli/main.js && printf '#!/usr/bin/env node\\n' | cat - dist/cli/main.js > dist/cli/main.tmp && mv dist/cli/main.tmp dist/cli/main.js && chmod +x dist/cli/main.js",
    "prepublishOnly": "bun run build",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "js-yaml": "^4.1.0",
    "ulidx": "^2.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.1",
    "bun-types": "^1.3.9",
    "typescript": "^5.7.0"
  },
  "trustedDependencies": ["@biomejs/biome", "better-sqlite3"]
}
